{
  "crons": [
    {
      "path": "/api/send-email",
      "schedule": "0 11 * * *"
    }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" },
        { "key": "Strict-Transport-Security", "value": "max-age=63072000; includeSubDomains; preload" },
        { "key": "Content-Security-Policy", "value": "default-src 'self'; script-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://www.googletagmanager.com; style-src 'self' 'unsafe-inline' https://fonts.googleapis.com https://fonts.gstatic.com; font-src 'self' https://fonts.gstatic.com; img-src 'self' data: https://*.supabase.co https://xztqawulvrtjvtfixofy.supabase.co; connect-src 'self' https://xztqawulvrtjvtfixofy.supabase.co https://fonts.bunny.net https://www.google-analytics.com; frame-ancestors 'none'; object-src 'none'; base-uri 'self'" },
        { "key": "X-Permitted-Cross-Domain-Policies", "value": "none" },
        { "key": "X-Robots-Tag", "value": "noindex, nofollow" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "https://app.attempo.cl" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, PATCH, DELETE, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, x-sa-token, x-internal-key, x-session-token, x-override-cliente-id, Authorization" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/api/gestionar-cita",             "destination": "/api/crear-cita" },
    { "source": "/api/flow-confirm",               "destination": "/api/flow" },
    { "source": "/api/flow-return",               "destination": "/api/flow?ret=1" },
    { "source": "/pago-exitoso",                  "destination": "/pago-exitoso.html" },
    { "source": "/api/reset-password",             "destination": "/api/login" },
    { "source": "/login",                          "destination": "/login.html" },
    { "source": "/admin",                          "destination": "/admin.html" },
    { "source": "/reset-password",                 "destination": "/reset-password.html" },
    { "source": "/superadmin",                     "destination": "/superadmin.html" },
    { "source": "/editor",                         "destination": "/editor.html" },
    { "source": "/landing",                        "destination": "/landing.html" },
    { "source": "/chat-frame",                     "destination": "/chat-frame.html" },
    { "source": "/attempo-booking",                "destination": "/attempo-booking.html" },
    { "source": "/attempo-dashboard",              "destination": "/attempo-dashboard.html" },
    { "source": "/agenda",                         "destination": "/admin.html" },
    { "source": "/agenda/:sub",                    "destination": "/admin.html" },
    { "source": "/clientes",                       "destination": "/admin.html" },
    { "source": "/ventas",                         "destination": "/admin.html" },
    { "source": "/reportes",                       "destination": "/admin.html" },
    { "source": "/configuracion",                  "destination": "/admin.html" },
    { "source": "/configuracion/:sub",             "destination": "/admin.html" },
    { "source": "/bandeja",                        "destination": "/admin.html" },
    { "source": "/bandeja/chatbot",               "destination": "/admin.html" },
    { "source": "/bandeja/canales",               "destination": "/admin.html" },
    { "source": "/bandeja/recordatorios",         "destination": "/admin.html" },
    { "source": "/liquidaciones",                  "destination": "/admin.html" },
    { "source": "/gc-callback",                     "destination": "/gc-callback.html" },
    { "source": "/privacidad",                      "destination": "/privacidad.html" },
    { "source": "/terminos",                        "destination": "/terminos.html" },
    { "source": "/gestionar-cita",                 "destination": "/gestionar-cita.html" },
    { "source": "/accesos",                        "destination": "/accesos.html" },
    { "source": "/reservar/:slug",                 "destination": "/attempo-booking.html" },
    { "source": "/:slug",                          "destination": "/attempo-booking.html" }
  ]
}
