{
  "cleanUrls": true,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Frame-Options", "value": "DENY" },
        { "key": "X-Content-Type-Options", "value": "nosniff" },
        { "key": "Referrer-Policy", "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy", "value": "camera=(), microphone=(), geolocation=()" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "https://app.attempo.cl" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, DELETE, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, x-sa-token, x-internal-key, x-session-token" }
      ]
    }
  ],
  "rewrites": [
    { "source": "/login",                          "destination": "/login.html" },
    { "source": "/admin",                          "destination": "/admin.html" },
    { "source": "/reset-password",                 "destination": "/reset-password.html" },
    { "source": "/superadmin",                     "destination": "/superadmin.html" },
    { "source": "/editor",                         "destination": "/editor.html" },
    { "source": "/landing",                        "destination": "/landing.html" },
    { "source": "/chat-frame",                     "destination": "/chat-frame.html" },
    { "source": "/attempo-booking",                "destination": "/attempo-booking.html" },
    { "source": "/attempo-dashboard",              "destination": "/attempo-dashboard.html" },
    { "source": "/agenda",                         "destination": "/admin.html" },
    { "source": "/agenda/:sub",                    "destination": "/admin.html" },
    { "source": "/clientes",                       "destination": "/admin.html" },
    { "source": "/ventas",                         "destination": "/admin.html" },
    { "source": "/reportes",                       "destination": "/admin.html" },
    { "source": "/configuracion",                  "destination": "/admin.html" },
    { "source": "/configuracion/:sub",             "destination": "/admin.html" },
    { "source": "/gc-callback",                     "destination": "/gc-callback.html" },
    { "source": "/privacidad",                      "destination": "/privacidad.html" },
    { "source": "/terminos",                        "destination": "/terminos.html" },
    { "source": "/gestionar-cita",                 "destination": "/gestionar-cita.html" },
    { "source": "/accesos",                        "destination": "/accesos.html" },
    { "source": "/reservar/:slug",                 "destination": "/booking.html" },
    { "source": "/:slug",                          "destination": "/booking.html" }
  ]
}
